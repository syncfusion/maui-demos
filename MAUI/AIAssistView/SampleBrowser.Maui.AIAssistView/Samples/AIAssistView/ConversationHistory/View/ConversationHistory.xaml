<?xml version="1.0" encoding="utf-8" ?>
<localCore:SampleView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                      xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                      x:Class="SampleBrowser.Maui.AIAssistView.SfAIAssistView.ConversationHistory"
                      xmlns:localCore="clr-namespace:SampleBrowser.Maui.Base;assembly=SampleBrowser.Maui.Base"
                      xmlns:chip="clr-namespace:Syncfusion.Maui.Core;assembly=Syncfusion.Maui.Core"
                      xmlns:button="clr-namespace:Syncfusion.Maui.Buttons;assembly=Syncfusion.Maui.Buttons"
                      xmlns:popup="clr-namespace:Syncfusion.Maui.Popup;assembly=Syncfusion.Maui.Popup"
                      xmlns:aiAssist="clr-namespace:Syncfusion.Maui.AIAssistView;assembly=Syncfusion.Maui.AIAssistView"
                      xmlns:local="clr-namespace:SampleBrowser.Maui.AIAssistView.SfAIAssistView"
                      xmlns:imageExtension="clr-namespace:SampleBrowser.Maui.Base.Converters;assembly=SampleBrowser.Maui.Base"
                      xmlns:thickness="clr-namespace:Microsoft.Maui;assembly=Microsoft.Maui"
                      x:Name="sampleView">
    <localCore:SampleView.BindingContext>
        <local:GettingStartedViewModel x:Name="viewModel"/>
    </localCore:SampleView.BindingContext>
    <localCore:SampleView.Behaviors>
        <local:SfAIAssistViewConversationBehavior/>
    </localCore:SampleView.Behaviors>
    <localCore:SampleView.Resources>
        <ResourceDictionary>
            <ResourceDictionary>

                <!--#region Empty View-->
                <Grid x:Key="emptyView" 
                      RowDefinitions="Auto,Auto" 
                      RowSpacing="12" 
                      VerticalOptions="Center"
                      HorizontalOptions="Center">
                    <Label Text="Hi, How can I help you?" 
                           HorizontalOptions="Center" 
                           Grid.Row="0"  
                           LineHeight="1.2"
                           FontFamily="Roboto-Regular" 
                           FontSize="26" 
                           FontAttributes="Bold"/>
                    <Grid Grid.Row="1" RowDefinitions="Auto"  MaximumHeightRequest="240" Margin="32,8, 32, 8"  RowSpacing="0" VerticalOptions="Center" HorizontalOptions="Center">
                        <Border x:Name="emptyViewBorder"
                                StrokeThickness="1"  
                                Background="{AppThemeBinding Light={StaticResource TileBackgroundLight}, Dark={StaticResource TileBackground}}" 
                                Stroke="{AppThemeBinding Light={StaticResource BorderLight},Dark={StaticResource Border}}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="16" />
                            </Border.StrokeShape>
                            <Grid RowDefinitions="*,Auto" Padding="{OnPlatform Android='8,12,0,0', Default='8,6,0,0'}" Background="Transparent">
                                <aiAssist:RequestEditorView x:Name="editor"
                                        Background="{AppThemeBinding Light={StaticResource TileBackgroundLight}, Dark={StaticResource TileBackground}}"
                                        Placeholder="Type Message..."
                                        PlaceholderColor="{AppThemeBinding Dark={StaticResource PlaceholderTextColour},Light={StaticResource PlaceholderTextColourLight}}"
                                        AutoSize="TextChanges"
                                        MaximumHeightRequest="88"
                                        TextColor="{AppThemeBinding Dark={StaticResource TextColourAlt1},Light={StaticResource TextColourAlt1Light}}"
                                        Text="{Binding Source={x:Reference sfAIAssistView}, Path=BindingContext.InputText}">
                                    <aiAssist:RequestEditorView.Behaviors>
                                        <local:EditorTextChangedBehavior/>
                                    </aiAssist:RequestEditorView.Behaviors>
                                </aiAssist:RequestEditorView>
                                <popup:SfPopup Grid.Row="1"
                                               AutoSizeMode="Both"
                                               RelativeView="{x:Reference emptyViewBorder}"
                                               RelativePosition="AlignBottom"
                                               ShowHeader="False"
                                               IsOpen="{Binding IsPopupOpen}">
                                    <popup:SfPopup.PopupStyle>
                                        <popup:PopupStyle CornerRadius="10"
                                                           HasShadow="True"
                                                           OverlayColor="Transparent" />
                                    </popup:SfPopup.PopupStyle>
                                    <popup:SfPopup.ContentTemplate>
                                        <DataTemplate>
                                            <Grid ColumnDefinitions="30,Auto"
                                                  ColumnSpacing="5"
                                                  Padding="10"
                                                  HeightRequest="45"
                                                  WidthRequest="220"
                                                  HorizontalOptions="Center"
                                                  VerticalOptions="Center"
                                                  Background="{AppThemeBinding Light={StaticResource TileBackgroundLight}, Dark={StaticResource TileBackground}}">
                                                <Label Text="&#xe787;"
                                                       FontFamily="MauiSampleFontIcon"
                                                       FontSize="20"
                                                       Grid.Column="0"
                                                       HorizontalTextAlignment="Center"
                                                       VerticalTextAlignment="Center"
                                                       TextColor="{AppThemeBinding Dark={StaticResource TextColourAlt1},Light={StaticResource TextColourAlt1Light}}" />
                                                <Label Text="Upload from computer"
                                                       Grid.Column="1"
                                                       FontSize="16"
                                                       HorizontalTextAlignment="Center"
                                                       VerticalTextAlignment="Center"
                                                       TextColor="{AppThemeBinding Dark={StaticResource TextColour},Light={StaticResource TextColourLight}}"
                                                       CharacterSpacing="0.15"
                                                       FontFamily="Roboto-Regular" />
                                            </Grid>
                                        </DataTemplate>
                                    </popup:SfPopup.ContentTemplate>
                                </popup:SfPopup>
                                <Grid ColumnDefinitions="Auto,*,Auto,Auto"
                                      Grid.Row="1"
                                      Padding="0,0,8,8"
                                      VerticalOptions="End">
                                    <Border x:Name="addButton" 
                                            Stroke="Transparent" 
                                            Grid.Column="0" 
                                            HeightRequest="42" 
                                            WidthRequest="42">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="21"/>
                                        </Border.StrokeShape>
                                        <local:SfEffectsViewAdv HighlightBackground="{AppThemeBinding Light=#000000,Dark=#FFFFFF}" 
                                            RippleBackground="{AppThemeBinding Light=#000000,Dark=#FFFFFF}">
                                            <local:SfEffectsViewAdv.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding EmptyViewPopupIsOpen}"/>
                                            </local:SfEffectsViewAdv.GestureRecognizers>
                                            <Grid>
                                                <Label Text="&#xe771;" FontFamily="MauiSampleFontIcon" FontSize="20" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" TextColor="{AppThemeBinding Dark=#CAC4D0,Light=#49454F}" />
                                            </Grid>
                                        </local:SfEffectsViewAdv >
                                    </Border>

                                    <Border x:Name="micButton" 
                                            Stroke="Transparent"
                                            Grid.Column="2" 
                                            Background="Transparent"
                                            HeightRequest="42" 
                                            WidthRequest="42">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="21"/>
                                        </Border.StrokeShape>
                                        <Border.Triggers>
                                            <DataTrigger TargetType="Border" Binding="{Binding IsListening}" Value="True">
                                                <Setter Property="Background" Value="{AppThemeBinding Dark={StaticResource PrimaryBackground},Light={StaticResource PrimaryBackgroundLight}}"/>
                                            </DataTrigger>
                                        </Border.Triggers>
                                        <local:SfEffectsViewAdv HighlightBackground="{AppThemeBinding Light=#000000,Dark=#FFFFFF}" 
                                            RippleBackground="{AppThemeBinding Light=#000000,Dark=#FFFFFF}">
                                            <local:SfEffectsViewAdv.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding StartListeningCommand}"/>
                                            </local:SfEffectsViewAdv.GestureRecognizers>
                                            <Grid>
                                                <Label Text="&#xE76A;" 
                                                       FontFamily="MauiSampleFontIcon" 
                                                       FontSize="20" BindingContext="{x:Reference viewModel}" 
                                                       TextColor="{AppThemeBinding Dark=#CAC4D0,Light=#49454F}"
                                                       HorizontalTextAlignment="Center" VerticalTextAlignment="Center">
                                                    <Label.Triggers>
                                                        <DataTrigger TargetType="Label" Binding="{Binding IsListening}" Value="True">
                                                            <Setter Property="TextColor" Value="{AppThemeBinding Dark={StaticResource PrimaryForeground},Light={StaticResource White}}" />
                                                        </DataTrigger>
                                                    </Label.Triggers>
                                                </Label>
                                            </Grid>
                                        </local:SfEffectsViewAdv >
                                    </Border>

                                    <Border x:Name="sendButton" 
                                            Stroke="Transparent"
                                            Grid.Column="3"
                                            HeightRequest="42" WidthRequest="42"
                                            IsVisible="{Binding IsSendButtonVisible}"
                                            IsEnabled="{Binding EnableSendIcon}"
                                            Scale="1"
                                            Rotation="0">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="21"/>
                                        </Border.StrokeShape>
                                        <local:SfEffectsViewAdv HighlightBackground="{AppThemeBinding Light=#000000,Dark=#FFFFFF}"
                                            RippleBackground="{AppThemeBinding Light=#000000,Dark=#FFFFFF}">
                                            <local:SfEffectsViewAdv.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding SendButtonCommand}"/>
                                            </local:SfEffectsViewAdv.GestureRecognizers>
                                            <Grid WidthRequest="42" HeightRequest="42">
                                                <Label x:Name="sendIcon" Text="&#xE76F;" 
                                                       FontFamily="MauiSampleFontIcon" FontSize="20"
                                                       HorizontalTextAlignment="Center" 
                                                       VerticalTextAlignment="Center" Padding="5,0,0,0"
                                                       HeightRequest="42" WidthRequest="42" >
                                                    <Label.Triggers>
                                                        <DataTrigger TargetType="Label" Binding="{Binding EnableSendIcon}" Value="False">
                                                            <Setter Property="TextColor" Value="{AppThemeBinding Light=#611c1b1f, Dark=#61e6e1e5}"/>
                                                        </DataTrigger>
                                                        <DataTrigger TargetType="Label" Binding="{Binding EnableSendIcon}" Value="True">
                                                            <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource IconColourPressedLight}, Dark={StaticResource IconColourPressed}}"/>
                                                        </DataTrigger>
                                                    </Label.Triggers>
                                                </Label>
                                            </Grid>
                                        </local:SfEffectsViewAdv >
                                    </Border>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
                <!--#endregion-->

                <!--#region Editor Template-->
                <DataTemplate x:Key="editorViewTemplate">
                    <Grid Grid.Row="1" RowDefinitions="Auto" Margin="16,0" IsVisible="{Binding IsEditorVisible}" MaximumHeightRequest="240" RowSpacing="0" VerticalOptions="Center" HorizontalOptions="Center">
                        <Border x:Name="customEditorBorder"
                                StrokeThickness="1"  
                                Background="{AppThemeBinding Light={StaticResource TileBackgroundLight}, Dark={StaticResource TileBackground}}" 
                                Stroke="{AppThemeBinding Light={StaticResource BorderLight},Dark={StaticResource Border}}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="16" />
                            </Border.StrokeShape>
                            <Grid RowDefinitions="*,Auto" Padding="{OnPlatform Android='8,12,0,0', Default='8,6,0,0'}" Background="Transparent">
                                <aiAssist:RequestEditorView x:Name="editor"
                                        Background="{AppThemeBinding Light={StaticResource TileBackgroundLight}, Dark={StaticResource TileBackground}}"
                                        Placeholder="Type Message..."
                                        PlaceholderColor="{AppThemeBinding Dark={StaticResource PlaceholderTextColour},Light={StaticResource PlaceholderTextColourLight}}"
                                        AutoSize="TextChanges"
                                        MaximumHeightRequest="88"
                                        TextColor="{AppThemeBinding Dark={StaticResource TextColourAlt1},Light={StaticResource TextColourAlt1Light}}"
                                        Text="{Binding Source={x:Reference sfAIAssistView}, Path=BindingContext.InputText}">
                                    <aiAssist:RequestEditorView.Behaviors>
                                        <local:EditorTextChangedBehavior/>
                                    </aiAssist:RequestEditorView.Behaviors>
                                </aiAssist:RequestEditorView>
                                <popup:SfPopup Grid.Row="1"
                                       AutoSizeMode="Both"
                                       RelativeView="{x:Reference customEditorBorder}"
                                       RelativePosition="AlignTop"
                                       ShowHeader="False"
                                       IsOpen="{Binding IsTemporaryPopup}">
                                    <popup:SfPopup.PopupStyle>
                                        <popup:PopupStyle CornerRadius="10"
                                                          HasShadow="True"
                                                          OverlayColor="Transparent" />
                                    </popup:SfPopup.PopupStyle>
                                    <popup:SfPopup.ContentTemplate>
                                        <DataTemplate>
                                            <Grid ColumnDefinitions="30,Auto"
                                                  ColumnSpacing="5"
                                                  Padding="10"
                                                  HeightRequest="45"
                                                  WidthRequest="220"
                                                  HorizontalOptions="Center"
                                                  VerticalOptions="Center"
                                                  Background="{AppThemeBinding Light={StaticResource TileBackgroundLight}, Dark={StaticResource TileBackground}}">
                                                <Label Text="&#xe787;"
                                                       FontFamily="MauiSampleFontIcon"
                                                       FontSize="20"
                                                       Grid.Column="0"
                                                       HorizontalTextAlignment="Center"
                                                       VerticalTextAlignment="Center"
                                                       TextColor="{AppThemeBinding Dark={StaticResource TextColourAlt1},Light={StaticResource TextColourAlt1Light}}" />
                                                <Label Text="Upload from computer"
                                                       Grid.Column="1"
                                                       FontSize="16"
                                                       HorizontalTextAlignment="Center"
                                                       VerticalTextAlignment="Center"
                                                       TextColor="{AppThemeBinding Dark={StaticResource TextColour},Light={StaticResource TextColourLight}}"
                                                       CharacterSpacing="0.15"
                                                       FontFamily="Roboto-Regular" />
                                            </Grid>
                                        </DataTemplate>
                                    </popup:SfPopup.ContentTemplate>
                                </popup:SfPopup>
                                <Grid ColumnDefinitions="Auto,*,Auto,Auto"
                                      Grid.Row="1"
                                      Padding="0,0,8,8"
                                      VerticalOptions="End">
                                    <Border x:Name="attachment" 
                                            Stroke="Transparent" 
                                            Grid.Column="0" 
                                            HeightRequest="42" 
                                            WidthRequest="42">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="21"/>
                                        </Border.StrokeShape>
                                        <local:SfEffectsViewAdv HighlightBackground="{AppThemeBinding Light=#000000,Dark=#FFFFFF}" 
                                            RippleBackground="{AppThemeBinding Light=#000000,Dark=#FFFFFF}">
                                            <local:SfEffectsViewAdv.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding TemporaryPopupCommad}"/>
                                            </local:SfEffectsViewAdv.GestureRecognizers>
                                            <Grid>
                                                <Label Text="&#xe771;" FontFamily="MauiSampleFontIcon" FontSize="20" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" TextColor="{AppThemeBinding Dark=#CAC4D0,Light=#49454F}" />
                                            </Grid>
                                        </local:SfEffectsViewAdv >
                                    </Border>

                                    <Border x:Name="micButton" 
                                            Stroke="Transparent"
                                            Grid.Column="2" 
                                            Background="Transparent"
                                            HeightRequest="42" 
                                            WidthRequest="42">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="21"/>
                                        </Border.StrokeShape>
                                        <Border.Triggers>
                                            <DataTrigger TargetType="Border" Binding="{Binding IsListening}" Value="True">
                                                <Setter Property="Background" Value="{AppThemeBinding Dark={StaticResource PrimaryBackground},Light={StaticResource PrimaryBackgroundLight}}"/>
                                            </DataTrigger>
                                        </Border.Triggers>
                                        <local:SfEffectsViewAdv HighlightBackground="{AppThemeBinding Light=#000000,Dark=#FFFFFF}" 
                                            RippleBackground="{AppThemeBinding Light=#000000,Dark=#FFFFFF}">
                                            <local:SfEffectsViewAdv.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding StartListeningCommand}"/>
                                            </local:SfEffectsViewAdv.GestureRecognizers>
                                            <Grid>
                                                <Label Text="&#xE76A;" 
                                                       FontFamily="MauiSampleFontIcon" 
                                                       FontSize="20" BindingContext="{x:Reference viewModel}" 
                                                       TextColor="{AppThemeBinding Dark=#CAC4D0,Light=#49454F}"
                                                       HorizontalTextAlignment="Center" VerticalTextAlignment="Center">
                                                    <Label.Triggers>
                                                        <DataTrigger TargetType="Label" Binding="{Binding IsListening}" Value="True">
                                                            <Setter Property="TextColor" Value="{AppThemeBinding Dark={StaticResource PrimaryForeground},Light={StaticResource White}}" />
                                                        </DataTrigger>
                                                    </Label.Triggers>
                                                </Label>
                                            </Grid>
                                        </local:SfEffectsViewAdv >
                                    </Border>

                                    <Border x:Name="sendButton" 
                                            Stroke="Transparent"
                                            Grid.Column="3"
                                            HeightRequest="42" WidthRequest="42"
                                            IsVisible="{Binding IsSendButtonVisible}"
                                            IsEnabled="{Binding EnableSendIcon}"
                                            Scale="1"
                                            Rotation="0">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="21"/>
                                        </Border.StrokeShape>
                                        <local:SfEffectsViewAdv HighlightBackground="{AppThemeBinding Light=#000000,Dark=#FFFFFF}"
                                            RippleBackground="{AppThemeBinding Light=#000000,Dark=#FFFFFF}">
                                            <local:SfEffectsViewAdv.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding SendButtonCommand}"/>
                                            </local:SfEffectsViewAdv.GestureRecognizers>
                                            <Grid WidthRequest="42" HeightRequest="42">
                                                <Label x:Name="sendIcon" 
                                                       Text="&#xE76F;" 
                                                       FontFamily="MauiSampleFontIcon" FontSize="20"
                                                       HorizontalTextAlignment="Center" 
                                                       VerticalTextAlignment="Center" Padding="5,0,0,0"
                                                       HeightRequest="42" WidthRequest="42" >
                                                    <Label.Triggers>
                                                        <DataTrigger TargetType="Label" Binding="{Binding EnableSendIcon}" Value="False">
                                                            <Setter Property="TextColor" Value="{AppThemeBinding Light=#611c1b1f, Dark=#61e6e1e5}"/>
                                                        </DataTrigger>
                                                        <DataTrigger TargetType="Label" Binding="{Binding EnableSendIcon}" Value="True">
                                                            <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource IconColourPressedLight}, Dark={StaticResource IconColourPressed}}"/>
                                                        </DataTrigger>
                                                    </Label.Triggers>
                                                </Label>
                                            </Grid>
                                        </local:SfEffectsViewAdv >
                                    </Border>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </DataTemplate>
                <!--#endregion-->

                <!--#region TemporaryBannerTemplate template-->
                <DataTemplate x:Key="temporaryChat">
                    <Grid RowDefinitions="Auto, Auto"
                          RowSpacing="12"
                          VerticalOptions="Center"
                          HorizontalOptions="Center">
                        <Grid ColumnDefinitions="Auto, AUto" VerticalOptions="Center" ColumnSpacing="12" HorizontalOptions="Center">
                            <Label Text="&#xe7dc;" 
                                   Grid.Column="0"
                                   FontFamily="MauiMaterialAssets" 
                                   FontSize="24" 
                                   HorizontalOptions="Center"
                                   Margin="0,4,0,0"
                                   FontAttributes="Bold"/>
                            <Label Text="Temporary chat"
                                   Grid.Column="1"
                                   LineHeight="1.2"
                                   FontFamily="Roboto-Regular" 
                                   FontSize="26" 
                                   FontAttributes="Bold"/>
                        </Grid>
                        <Grid Grid.Row="1" RowDefinitions="Auto"  MaximumHeightRequest="240" Margin="32,8, 32, 8"  RowSpacing="0" VerticalOptions="Center" HorizontalOptions="Center">
                            <Border x:Name="temporaryBannerTemplateBorder"
                                StrokeThickness="1"  
                                Background="{AppThemeBinding Light={StaticResource TileBackgroundLight}, Dark={StaticResource TileBackground}}" 
                                Stroke="{AppThemeBinding Light={StaticResource BorderLight},Dark={StaticResource Border}}">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="16" />
                                </Border.StrokeShape>
                                <Grid RowDefinitions="*,Auto" Padding="{OnPlatform Android='8,12,0,0', Default='8,6,0,0'}" Background="Transparent">
                                    <aiAssist:RequestEditorView x:Name="editor"
                                        Background="{AppThemeBinding Light={StaticResource TileBackgroundLight}, Dark={StaticResource TileBackground}}"
                                        Placeholder="Type Message..."
                                        PlaceholderColor="{AppThemeBinding Dark={StaticResource PlaceholderTextColour},Light={StaticResource PlaceholderTextColourLight}}"
                                        AutoSize="TextChanges"
                                        MaximumHeightRequest="88"
                                        TextColor="{AppThemeBinding Dark={StaticResource TextColourAlt1},Light={StaticResource TextColourAlt1Light}}"
                                        Text="{Binding Source={x:Reference sfAIAssistView}, Path=BindingContext.InputText}">
                                        <aiAssist:RequestEditorView.Behaviors>
                                            <local:EditorTextChangedBehavior/>
                                        </aiAssist:RequestEditorView.Behaviors>
                                    </aiAssist:RequestEditorView>
                                    <popup:SfPopup Grid.Row="1"
                                                   AutoSizeMode="Both"
                                                   RelativeView="{x:Reference temporaryBannerTemplateBorder}"
                                                   RelativePosition="AlignBottom"
                                                   ShowHeader="False"
                                                   IsOpen="{Binding IsAttachmentPopupOpen}">
                                        <popup:SfPopup.PopupStyle>
                                            <popup:PopupStyle CornerRadius="10"
                                                              HasShadow="True"
                                                              OverlayColor="Transparent" />
                                        </popup:SfPopup.PopupStyle>
                                        <popup:SfPopup.ContentTemplate>
                                            <DataTemplate>
                                                <Grid ColumnDefinitions="30,Auto"
                                                      ColumnSpacing="5"
                                                      Padding="10"
                                                      HeightRequest="45"
                                                      WidthRequest="220"
                                                      HorizontalOptions="Center"
                                                      VerticalOptions="Center"
                                                      Background="{AppThemeBinding Light={StaticResource TileBackgroundLight}, Dark={StaticResource TileBackground}}">
                                                    <Label Text="&#xe787;"
                                                           FontFamily="MauiSampleFontIcon"
                                                           FontSize="20"
                                                           Grid.Column="0"
                                                           HorizontalTextAlignment="Center"
                                                           VerticalTextAlignment="Center"
                                                           TextColor="{AppThemeBinding Dark={StaticResource TextColourAlt1},Light={StaticResource TextColourAlt1Light}}" />
                                                    <Label Text="Upload from computer"
                                                            Grid.Column="1"
                                                            FontSize="16"
                                                            HorizontalTextAlignment="Center"
                                                            VerticalTextAlignment="Center"
                                                            TextColor="{AppThemeBinding Dark={StaticResource TextColour},Light={StaticResource TextColourLight}}"
                                                            CharacterSpacing="0.15"
                                                            FontFamily="Roboto-Regular" />
                                                </Grid>
                                            </DataTemplate>
                                        </popup:SfPopup.ContentTemplate>
                                    </popup:SfPopup>
                                    <Grid ColumnDefinitions="Auto,*,Auto,Auto"
                                          Grid.Row="1"
                                          Padding="0,0,8,8"
                                          VerticalOptions="End">
                                        <Border x:Name="attachmentButton" 
                                                Stroke="Transparent" 
                                                Grid.Column="0" 
                                                HeightRequest="42" 
                                                WidthRequest="42">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="21"/>
                                            </Border.StrokeShape>
                                            <local:SfEffectsViewAdv HighlightBackground="{AppThemeBinding Light=#000000,Dark=#FFFFFF}" 
                                            RippleBackground="{AppThemeBinding Light=#000000,Dark=#FFFFFF}">
                                                <local:SfEffectsViewAdv.GestureRecognizers>
                                                    <TapGestureRecognizer Command="{Binding AttachmentButtonCommand}"/>
                                                </local:SfEffectsViewAdv.GestureRecognizers>
                                                <Grid>
                                                    <Label Text="&#xe771;" FontFamily="MauiSampleFontIcon" FontSize="20" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" TextColor="{AppThemeBinding Dark=#CAC4D0,Light=#49454F}" />
                                                </Grid>
                                            </local:SfEffectsViewAdv >
                                        </Border>

                                        <Border x:Name="micButton" 
                                                Stroke="Transparent"
                                                Grid.Column="2" 
                                                Background="Transparent"
                                                HeightRequest="42" 
                                                WidthRequest="42">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="21"/>
                                            </Border.StrokeShape>
                                            <Border.Triggers>
                                                <DataTrigger TargetType="Border" Binding="{Binding IsListening}" Value="True">
                                                    <Setter Property="Background" Value="{AppThemeBinding Dark={StaticResource PrimaryBackground},Light={StaticResource PrimaryBackgroundLight}}"/>
                                                </DataTrigger>
                                            </Border.Triggers>
                                            <local:SfEffectsViewAdv HighlightBackground="{AppThemeBinding Light=#000000,Dark=#FFFFFF}" 
                                            RippleBackground="{AppThemeBinding Light=#000000,Dark=#FFFFFF}">
                                                <local:SfEffectsViewAdv.GestureRecognizers>
                                                    <TapGestureRecognizer Command="{Binding StartListeningCommand}"/>
                                                </local:SfEffectsViewAdv.GestureRecognizers>
                                                <Grid>
                                                    <Label Text="&#xE76A;" 
                                                           FontFamily="MauiSampleFontIcon" 
                                                           FontSize="20" BindingContext="{x:Reference viewModel}" 
                                                           TextColor="{AppThemeBinding Dark=#CAC4D0,Light=#49454F}"
                                                           HorizontalTextAlignment="Center" VerticalTextAlignment="Center">
                                                        <Label.Triggers>
                                                            <DataTrigger TargetType="Label" Binding="{Binding IsListening}" Value="True">
                                                                <Setter Property="TextColor" Value="{AppThemeBinding Dark={StaticResource PrimaryForeground},Light={StaticResource White}}" />
                                                            </DataTrigger>
                                                        </Label.Triggers>
                                                    </Label>
                                                </Grid>
                                            </local:SfEffectsViewAdv >
                                        </Border>

                                        <Border x:Name="sendButton" Stroke="Transparent"
                                                Grid.Column="3"
                                                HeightRequest="42" WidthRequest="42"
                                                IsVisible="{Binding IsSendButtonVisible}"
                                                IsEnabled="{Binding EnableSendIcon}"
                                                Scale="1"
                                                Rotation="0">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="21"/>
                                            </Border.StrokeShape>
                                            <local:SfEffectsViewAdv HighlightBackground="{AppThemeBinding Light=#000000,Dark=#FFFFFF}"
                                            RippleBackground="{AppThemeBinding Light=#000000,Dark=#FFFFFF}">
                                                <local:SfEffectsViewAdv.GestureRecognizers>
                                                    <TapGestureRecognizer Command="{Binding SendButtonCommand}"/>
                                                </local:SfEffectsViewAdv.GestureRecognizers>
                                                <Grid WidthRequest="42" HeightRequest="42">
                                                    <Label x:Name="sendIcon" Text="&#xE76F;" 
                                                           FontFamily="MauiSampleFontIcon" FontSize="20"
                                                           HorizontalTextAlignment="Center" 
                                                           VerticalTextAlignment="Center" Padding="5,0,0,0"
                                                           HeightRequest="42" WidthRequest="42" >
                                                        <Label.Triggers>
                                                            <DataTrigger TargetType="Label" Binding="{Binding EnableSendIcon}" Value="False">
                                                                <Setter Property="TextColor" Value="{AppThemeBinding Light=#611c1b1f, Dark=#61e6e1e5}"/>
                                                            </DataTrigger>
                                                            <DataTrigger TargetType="Label" Binding="{Binding EnableSendIcon}" Value="True">
                                                                <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource IconColourPressedLight}, Dark={StaticResource IconColourPressed}}"/>
                                                            </DataTrigger>
                                                        </Label.Triggers>
                                                    </Label>
                                                </Grid>
                                            </local:SfEffectsViewAdv >
                                        </Border>
                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </DataTemplate>
                <!--#endregion-->

            </ResourceDictionary>
        </ResourceDictionary>
    </localCore:SampleView.Resources>
    <localCore:SampleView.Content>
        
        <!--#region SfAIAssistView-->
        <local:CustomAssistView x:Name="sfAIAssistView"
                                ToolbarTitle="AI AssistView"
                                ConversationItemsSource="{Binding History}"
                                InputText="{Binding InputText}"
                                AutoSuggestionOverlay="{Binding AutoSuggestionOverlay}"
