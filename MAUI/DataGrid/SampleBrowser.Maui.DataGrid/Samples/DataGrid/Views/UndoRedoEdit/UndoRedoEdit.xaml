<?xml version="1.0" encoding="utf-8" ?>
<localCore:SampleView x:Class="SampleBrowser.Maui.DataGrid.SfDataGrid.UndoRedoEdit"
                      xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                      xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                      xmlns:tabView="clr-namespace:Syncfusion.Maui.TabView;assembly=Syncfusion.Maui.TabView"
                      xmlns:local="clr-namespace:SampleBrowser.Maui.DataGrid"
                      xmlns:localCore="clr-namespace:SampleBrowser.Maui.Base;assembly=SampleBrowser.Maui.Base"
                      xmlns:effectsView="clr-namespace:Syncfusion.Maui.Core;assembly=Syncfusion.Maui.Core"
                      xmlns:sfgrid="clr-namespace:Syncfusion.Maui.DataGrid;assembly=Syncfusion.Maui.DataGrid">

    <localCore:SampleView.BindingContext>
        <local:DealerInfoViewModel />
    </localCore:SampleView.BindingContext>

    <localCore:SampleView.Resources>
        <ResourceDictionary>
            <local:ItemSourceSelector x:Key="convertor"/>
            <local:CountToBoolConverter x:Key="undoRedoCountConverter"/>
            <local:CountToOpacityConverter x:Key="countToOpacityConverter"/>
        </ResourceDictionary>
        <OnPlatform x:Key="minimumWidth" x:TypeArguments="x:Double">
            <On Platform="Android,iOS" Value="120"></On>
        </OnPlatform>
        <OnPlatform x:Key="productMinimumWidth" x:TypeArguments="x:Double">
            <On Platform="Android" Value="140"></On>
            <On Platform="iOS" Value="140"></On>
        </OnPlatform>
        <OnPlatform x:Key="margin" x:TypeArguments="Thickness">
            <On Platform="WinUI" Value="-4"/>
            <On Platform="MacCatalyst" Value="-4"/>
        </OnPlatform>
        <Style TargetType="sfgrid:DataGridHeaderCell">
            <Setter Property="FontFamily"
                    Value="Roboto-Medium" />
            <Setter Property="FontSize"
                    Value="14" />
            <Setter Property="Padding">
                <Setter.Value>
                    <OnPlatform x:TypeArguments="Thickness">
                        <On Platform="iOS,WinUI,MacCatalyst"
                            Value="16,14" />
                        <On Platform="Android"
                            Value="16,17" />
                    </OnPlatform>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="sfgrid:DataGridCell">
            <Setter Property="FontSize"
                    Value="14" />
        </Style>
        <OnPlatform x:Key="visibility" x:TypeArguments="x:Boolean">
            <On Platform="Windows,MacCatalyst" Value="false"/>
            <On Platform="Android,iOS" Value="true"/>
        </OnPlatform>
        <Color x:Key="GridLightColor">#F7F2FB</Color>
        <Color x:Key="GridDarkColor">#25232A</Color>
    </localCore:SampleView.Resources>

    <localCore:SampleView.Content>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="{OnPlatform Android=56, iOS=56, WinUI=0, MacCatalyst=0}" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" BackgroundColor="{AppThemeBinding Light={StaticResource GridLightColor}, Dark={StaticResource GridDarkColor}}" ColumnDefinitions="Auto,Auto" Padding="8,0,0,0" IsVisible="{StaticResource visibility}">

                <Grid VerticalOptions="Center" Grid.Column="0">
                    <effectsView:SfEffectsView VerticalOptions="Center" MinimumWidthRequest="65" HeightRequest="36" IsEnabled="{Binding Source={x:Reference dataGrid}, Path=UndoRedoController.UndoCount, Mode=OneWay, Converter={StaticResource undoRedoCountConverter}}" x:Name="undoButton" TouchUp="undoButton_TouchUp" >
                        <Grid ColumnDefinitions="Auto,Auto" VerticalOptions="Center" HorizontalOptions="Center" Opacity="{Binding Source={x:Reference dataGrid}, Path=UndoRedoController.UndoCount, Mode=OneWay, Converter={StaticResource countToOpacityConverter}}">
                            <Label Text="&#xe744;" FontFamily="MauiMaterialAssets" Grid.Column="0" FontSize="18"/>
                            <Label Text="Undo" Margin="4,0,0,0"  Grid.Column="1"/>
                        </Grid>
                    </effectsView:SfEffectsView>
                </Grid>

                <Grid Margin="8,0,0,0" VerticalOptions="Center" Grid.Column="1">
                    <effectsView:SfEffectsView VerticalOptions="Center" MinimumWidthRequest="65" HeightRequest="36" IsEnabled="{Binding Source={x:Reference dataGrid}, Path=UndoRedoController.RedoCount, Mode=OneWay, Converter={StaticResource undoRedoCountConverter}}" x:Name="redoButton" TouchUp="redoButton_TouchUp" >
                        <Grid ColumnDefinitions="Auto,Auto" VerticalOptions="Center" HorizontalOptions="Center" Opacity="{Binding Source={x:Reference dataGrid}, Path=UndoRedoController.RedoCount, Mode=OneWay, Converter={StaticResource countToOpacityConverter}}">
                            <Label Text="&#xe745;" FontFamily="MauiMaterialAssets" Grid.Column="0" FontSize="18"/>
                            <Label Text="Redo" Grid.Column="1" Margin="4,0,0,0" />
                        </Grid>
                    </effectsView:SfEffectsView>
                </Grid>
            </Grid>
            
            <sfgrid:SfDataGrid x:Name="dataGrid"
                               Grid.Row="2"
                               Margin="{StaticResource margin}"
                               x:DataType="local:DealerInfoViewModel"
                               ItemsSource="{Binding DealerInformation}"
                               AutoGenerateColumnsMode="None"
                               SelectionMode="Single"
                               AllowEditing="True"
                               ColumnWidthMode="Fill"
                               HeaderRowHeight="52"
                               RowHeight="48"
                               AllowUndoRedo="True">

                <sfgrid:SfDataGrid.Columns>

                    <sfgrid:DataGridNumericColumn Format="D"
                                                  HeaderText="Product Number"
                                                  MappingName="ProductNo"   
                                                  MinimumWidth="{StaticResource productMinimumWidth}">
                    </sfgrid:DataGridNumericColumn>

                    <sfgrid:DataGridTextColumn HeaderText="Name"
                                               MappingName="DealerName"
                                               MinimumWidth="{StaticResource minimumWidth}">
                    </sfgrid:DataGridTextColumn>

                    <sfgrid:DataGridDateColumn HeaderText="Shipped Date"
                                               MinimumWidth="{StaticResource minimumWidth}"
                                               MappingName="ShippedDate">
                    </sfgrid:DataGridDateColumn>

                    <sfgrid:DataGridComboBoxColumn HeaderText="Ship Country"
                                                   MappingName="ShipCountry"
                                                   HeaderTextAlignment="Start"
                                                   MinimumWidth="{StaticResource minimumWidth}"
                                                   ItemsSource="{Binding Countries}">
                    </sfgrid:DataGridComboBoxColumn>

                    <sfgrid:DataGridComboBoxColumn HeaderText="Ship City"
                                                   MappingName="ShipCity"
                                                   HeaderTextAlignment="Start"
                                                   MinimumWidth="{StaticResource minimumWidth}"
                                                   ItemsSourceSelector="{StaticResource convertor}">
                    </sfgrid:DataGridComboBoxColumn>

                    <sfgrid:DataGridNumericColumn Format="C"
                                                  HeaderText="Price"
                                                  MappingName="ProductPrice"
                                                  MinimumWidth="{StaticResource minimumWidth}">
                    </sfgrid:DataGridNumericColumn>

                </sfgrid:SfDataGrid.Columns>
            </sfgrid:SfDataGrid>
        </Grid>
        
    </localCore:SampleView.Content>
</localCore:SampleView>    