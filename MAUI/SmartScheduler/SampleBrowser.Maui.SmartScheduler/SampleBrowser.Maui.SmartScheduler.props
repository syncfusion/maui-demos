<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="15.0" DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

	<ItemGroup>
		<Compile Include="$(MSBuildThisFileDirectory)\Samples\SmartScheduler\View\GettingStarted.xaml.cs">
			<Link>Samples\SmartScheduler\View\GettingStarted.xaml.cs</Link>
			<DependentUpon>GettingStarted.xaml</DependentUpon>
		</Compile>

		<Compile Include="$(MSBuildThisFileDirectory)\Samples\SmartScheduler\ViewModel\SmartSchedulerViewModel.cs">
			<Link>Samples\SmartScheduler\ViewModel\SmartSchedulerViewModel.cs</Link>
		</Compile>

		<Compile Include="$(MSBuildThisFileDirectory)\Samples\SmartScheduler\Behavior\GettingStartedBehavior.cs">
			<Link>Samples\SmartScheduler\Behavior\GettingStartedBehavior.cs</Link>
		</Compile>
	</ItemGroup>

	<ItemGroup>
		<EmbeddedResource Include="$(MSBuildThisFileDirectory)\SmartSchedulerSamplesList.xml" >
			<Link>SmartSchedulerSamplesList.xml</Link>
		</EmbeddedResource>
	</ItemGroup>

	<ItemGroup>
		<MauiXaml Include="$(MSBuildThisFileDirectory)\Samples\SmartScheduler\View\GettingStarted.xaml">
			<Link>Samples\SmartScheduler\View\GettingStarted.xaml</Link>
		</MauiXaml>
	</ItemGroup>	
</Project>