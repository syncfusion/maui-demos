<?xml version="1.0" encoding="utf-8" ?>
<localCore:SampleView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SampleBrowser.Maui.LiquidGlass.SfSmartTextEditor.SmartTextEditorPage"
             xmlns:ste="clr-namespace:Syncfusion.Maui.SmartComponents;assembly=Syncfusion.Maui.SmartComponents"
             xmlns:localCore="clr-namespace:SampleBrowser.Maui.Base;assembly=SampleBrowser.Maui.Base"
             xmlns:local="clr-namespace:SampleBrowser.Maui.LiquidGlass.SfSmartTextEditor"
             xmlns:editors="clr-namespace:Syncfusion.Maui.Inputs;assembly=Syncfusion.Maui.Inputs"
             xmlns:core="clr-namespace:Syncfusion.Maui.Core;assembly=Syncfusion.Maui.Core"
             xmlns:imageExtention="clr-namespace:SampleBrowser.Maui.Base.Converters;assembly=SampleBrowser.Maui.Base">

    <localCore:SampleView.BindingContext>
        <local:SmartTextEditorViewModel/>
    </localCore:SampleView.BindingContext>

    <localCore:SampleView.Content>
        <Grid>
            <Border
                    Stroke="{AppThemeBinding Default={DynamicResource InputBoxBorder}}"
                    StrokeThickness="0.6"
                    HorizontalOptions="Center"
                    VerticalOptions="{OnPlatform Default=Center, iOS=Center}"
                    Padding="{OnPlatform Default=24, iOS=28}"
                    Margin="{OnPlatform Default=0,
                                        iOS='22,36,22,36'}"
                    MinimumWidthRequest="320"
                    MaximumWidthRequest="720">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="{OnPlatform Default=18, iOS=22}" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="#1C244B"
                            Radius="{OnPlatform Default=18, iOS=24}"
                            Offset="0,14"
                            Opacity="{OnPlatform Default=0.15, iOS=0.26}" />
                </Border.Shadow>

                <VerticalStackLayout Spacing="{OnPlatform Default=18, iOS=20}">

                    <StackLayout Spacing="{OnPlatform Default=10, iOS=13}">
                        <Label Text="Role"
                                FontSize="{OnPlatform Default=13, iOS=14}"
                                FontAttributes="Bold"
                                TextColor="{AppThemeBinding Light=#1A2844, Dark=#f5f6fa}" />
                        <core:SfGlassEffectView CornerRadius="5">
                            <editors:SfComboBox x:Name="comboBox" ItemsSource="{Binding Roles}" EnableLiquidGlassEffect="True"
                                DisplayMemberPath="Text"
                                TextMemberPath="Text"
                                SelectedItem="{Binding SelectedRole}"
                                IsClearButtonVisible="False"
                                Background="Transparent"
                                SelectedDropDownItemBackground="Transparent"
                                DropDownBackground="Transparent"
                                HorizontalOptions="Start">
                            </editors:SfComboBox>
                        </core:SfGlassEffectView>
                    </StackLayout>

                    <StackLayout Spacing="{OnPlatform Default=10, iOS=13}">
                        <Label Text="Response"
                                FontSize="{OnPlatform Default=13, iOS=14}"
                                FontAttributes="Bold"
                                TextColor="{AppThemeBinding Light=#1A2844, Dark=#f5f6fa}" />
                        <Border Stroke="{AppThemeBinding Default={DynamicResource InputBoxBorder}}"
                                StrokeThickness="0.6">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <core:SfGlassEffectView CornerRadius="8">
                                <ste:SfSmartTextEditor x:Name="smartTextEditor" Background="Transparent"
                                     EnableLiquidGlassEffect="True" SuggestionDisplayMode="Popup"
                                     HeightRequest="{OnPlatform Default=220, iOS=380}"
                                     UserRole="{Binding CurrentPreset.UserRole}"
                                     UserPhrases="{Binding CurrentPreset.UserPhrases}"
                                     Placeholder="{Binding CurrentPreset.PlaceHolder}"/>
                            </core:SfGlassEffectView>
                        </Border>
                    </StackLayout>
                </VerticalStackLayout>
            </Border>
        </Grid>
    </localCore:SampleView.Content>

    <localCore:SampleView.Behaviors>
        <local:SmartTextEditorBehavior />
    </localCore:SampleView.Behaviors>

</localCore:SampleView>