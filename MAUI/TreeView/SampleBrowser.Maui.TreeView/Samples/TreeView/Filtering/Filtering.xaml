<?xml version="1.0" encoding="utf-8" ?>
<localCore:SampleView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                      xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                      xmlns:localCore="clr-namespace:SampleBrowser.Maui.Base;assembly=SampleBrowser.Maui.Base"
                      xmlns:syncfusion="clr-namespace:Syncfusion.Maui.TreeView;assembly=Syncfusion.Maui.TreeView"
                      xmlns:converters="clr-namespace:SampleBrowser.Maui.Base.Converters;assembly=SampleBrowser.Maui.Base"
                      xmlns:treeviewengine="clr-namespace:Syncfusion.TreeView.Engine;assembly=Syncfusion.Maui.TreeView"
                      xmlns:editors="clr-namespace:Syncfusion.Maui.Inputs;assembly=Syncfusion.Maui.Inputs"
                      xmlns:chip="clr-namespace:Syncfusion.Maui.Core;assembly=Syncfusion.Maui.Core"
                      xmlns:thickness ="clr-namespace:Microsoft.Maui;assembly=Microsoft.Maui" 
                      x:Class="SampleBrowser.Maui.TreeView.SfTreeView.Filtering"
                      xmlns:local="clr-namespace:SampleBrowser.Maui.TreeView">

    <localCore:SampleView.BindingContext>
        <local:FileManagerViewModel x:Name="fileMangerViewmodel"/>
    </localCore:SampleView.BindingContext>
    <localCore:SampleView.Behaviors>
        <local:SfTreeViewGettingStartedBehavior />
    </localCore:SampleView.Behaviors>

    <localCore:SampleView.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <local:TreeViewStyles/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
        <DataTemplate x:Key="GettingStartedTemplate">
            <local:GettingStartedDataTemplate/>
        </DataTemplate>
    </localCore:SampleView.Resources>
    <localCore:SampleView.Content>
        <Border Style="{StaticResource TreeViewBorder}" MaximumWidthRequest="{OnPlatform WinUI=380, MacCatalyst=400}">
            <Border.StrokeShape>
                <RoundRectangle Style="{StaticResource roundedRectangle}" />
            </Border.StrokeShape>
            <Border.Margin>
                <OnPlatform x:TypeArguments="thickness:Thickness">
                    <On Platform="MacCatalyst" Value="20"/>
                    <On Platform="WinUI" Value="20"/>
                </OnPlatform>
            </Border.Margin>
            <Grid RowDefinitions="Auto, *" MaximumWidthRequest="{OnPlatform WinUI=350, MacCatalyst=400}">
                <Border Stroke="Transparent" Background="{AppThemeBinding Light={StaticResource TileBackgroundLight}, Dark={StaticResource TileBackground}}" Margin="8">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>
                    <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="8">
                        <Label Text="&#xe728;"
                               Style="{StaticResource IconStyle}"
                               FontFamily="MauiSampleFontIcon"
                               FontAttributes="Bold"
                               VerticalOptions="Center"
                               HorizontalOptions="Center"
                               FontSize="16"
                               Margin="12,0,0,0" />
                        <local:SfEntry x:Name="entry"
                                       Placeholder="Enter a text to filter"
                                       Background="Transparent"
                                       VerticalTextAlignment='{OnPlatform Default=Start, MacCatalyst=Center, iOS=Center}'
                                       Grid.Column="1"
                                       PlaceholderColor="{AppThemeBinding Light={StaticResource PlaceholderTextColourLight}, Dark={StaticResource PlaceholderTextColour}}"
                                       TextColor="{AppThemeBinding Light={StaticResource InputTextColourLight}, Dark={StaticResource InputTextColour}}"
                                       FontFamily="Roboto-Regular"
                                       FontSize="14"
                                       Text="{Binding FilterText}"
                                       HeightRequest="38"
                                       ClearButtonVisibility="Never"/>
                        <Border x:Name="clearICon"
                                Margin="0,0,3,0"
                                Grid.Column="2"
                                Stroke="Transparent"
                                StrokeThickness="0"
                                HeightRequest="24"
                                WidthRequest="24"
                                VerticalOptions="Center"
                                HorizontalOptions="Center"
                                IsVisible="{Binding EnableCancelIcon}">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12"/>
                                </Border.StrokeShape>
                                <local:SfEffectsViewAdv x:Name="clearIconEffects"
                                                        HeightRequest="24" 
                                                        WidthRequest="24" 
                                                        HighlightBackground="{AppThemeBinding Dark=White, Light=Black}"
                                                        RippleBackground="{AppThemeBinding Dark=White, Light=Black}">
                                    <local:SfEffectsViewAdv.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding ClearFilterCommand}"/>
                                    </local:SfEffectsViewAdv.GestureRecognizers>
                                    <Label Text="&#xe755;"
                                           FontSize="16"
                                           TextColor="{StaticResource IconColor}"
                                           FontFamily="MauiSampleFontIcon"
                                           FontAttributes="Bold"
                                           VerticalOptions="Center"
                                           HorizontalOptions="Center"
                                           VerticalTextAlignment="Center"
                                           HorizontalTextAlignment="Center"/>
                                </local:SfEffectsViewAdv>
                        </Border>
                    </Grid>
                </Border>
                <syncfusion:SfTreeView x:Name="treeView"
                                       Grid.Row="1"
                                       Margin="{OnPlatform WinUI='0,0,1,0', MacCatalyst='0,0,1,0'}"  
                                       ItemsSource="{Binding Folders}"
                                       NodePopulationMode="Instant"
                                       AutoExpandMode="AllNodesExpanded"
                                       FullRowSelect="True"
                                       ItemHeight="{OnPlatform Android=48, MacCatalyst=40, WinUI=40, iOS=48}"
                                       ExpandActionTarget="Node"
                                       ItemTemplate="{StaticResource GettingStartedTemplate}"
                                       FilterMode="Contains"
                                       FilterPath="FolderName"
                                       AutoExpandOnFilter="True">

                    <syncfusion:SfTreeView.HierarchyPropertyDescriptors>
                        <treeviewengine:HierarchyPropertyDescriptor TargetType="{x:Type local:Folder}" ChildPropertyName="FilesInfo"/>
                        <treeviewengine:HierarchyPropertyDescriptor TargetType="{x:Type local:File}" ChildPropertyName="SubFiles"/>
                    </syncfusion:SfTreeView.HierarchyPropertyDescriptors>

                </syncfusion:SfTreeView>
            </Grid>
        </Border>
    </localCore:SampleView.Content>

</localCore:SampleView>